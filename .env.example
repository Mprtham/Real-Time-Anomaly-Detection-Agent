# ── Redpanda ──────────────────────────────────────────────────────
REDPANDA_BROKERS=localhost:9092
CONSUMER_GROUP_ID=sentinel-processor

# ── Groq (get free key at console.groq.com) ───────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Slack (optional — leave blank to skip alerts) ─────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── Detection thresholds ──────────────────────────────────────────
ANOMALY_Z_THRESHOLD=3.0
TRIAGE_CONFIDENCE_CUTOFF=0.4
ESCALATION_CONFIDENCE=0.8
ALERT_COOLDOWN_MINUTES=10

# ── API ───────────────────────────────────────────────────────────
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","https://yourusername.github.io"]
